# Supabase — copy from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key — server-side only, never exposed to clients
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — for AI CV screening on application submit
# Leave empty to disable AI screening (applications still save)
ANTHROPIC_API_KEY=

# Upstash Redis — for rate limiting (optional but recommended in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Dashboard URL — used internally for cross-app links
# Replace localhost with this machine's LAN IP or a reachable hostname when testing from another device.
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_CAREERS_URL=http://localhost:3002

# Job alert emails — Resend (resend.com, free tier: 3 000/month)
RESEND_API_KEY=

# Job alert SMS — Africa's Talking (africastalking.com)
# Set username=sandbox for testing
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=SheerLogic

# Shared secret between dashboard → careers for the notify webhook
ALERT_NOTIFY_SECRET=
